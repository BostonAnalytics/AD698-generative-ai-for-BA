        "# Load Corpus and Configure API {#sec-setup}\n",
        "\n",
        "```python\n",
        "import pandas as pd\n",
        "\n",
        "chunks_df = pd.read_csv(\"/content/drive/MyDrive/assignment01/chunks.csv\")\n",
        "print(chunks_df.shape)\n",
