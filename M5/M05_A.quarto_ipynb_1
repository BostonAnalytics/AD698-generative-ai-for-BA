        "    a_rag, retrieved_a, retrieved_b = rag_answer(q, company_a_name, company_b_name)\n",
        "    a_pre = pretrain_answer(q, company_a_name, company_b_name)\n",
        "    answers.append({\n",
        "        \"question\": q,\n",
        "        \"zero_shot\": a_zero,\n",
        "        \"rag\": a_rag,\n",
        "        \"pretrain\": a_pre\n",
        "    })\n",
        "\n",
        "answers_df = pd.DataFrame(answers)\n",
        "print(answers_df.shape)\n",
        "answers_df.info()\n",
