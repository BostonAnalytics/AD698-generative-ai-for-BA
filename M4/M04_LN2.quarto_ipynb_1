        "# Full Fine-Tuning\n",
        "\n",
        "All model parameters are updated during training on labelled task data.\n",
        "\n",
        "### Classification Head"
      ],
      "id": "10e65f63"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import torch.nn as nn\n",
        "\n",
        "class TransformerClassifier(nn.Module):\n",
        "    \"\"\"\n",
        "    Wrap a frozen (or partially frozen) transformer encoder with a classification head.\n",
        "    In practice, replace `encoder` with a HuggingFace model.\n",
        "    \"\"\"\n",
        "    def __init__(self, encoder: nn.Module, hidden_dim: int, num_classes: int,\n",
        "                 dropout: float = 0.1):\n",
        "        super().__init__()\n",
        "        self.encoder    = encoder\n",
        "        self.dropout    = nn.Dropout(dropout)\n",
        "        self.classifier = nn.Linear(hidden_dim, num_classes)\n",
        "\n",
        "    def forward(self, x):\n",
        "        # x: (B, T) token ids → (B, T, H) hidden states\n",
        "        hidden = self.encoder(x)          # placeholder call\n",
        "        cls    = hidden[:, 0, :]          # take [CLS] representation\n",
        "        return self.classifier(self.dropout(cls))"
      ],
