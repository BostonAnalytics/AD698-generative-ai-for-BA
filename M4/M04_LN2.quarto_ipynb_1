        "#| eval: false\n",
        "def zero_shot_prompt(task: str, input_text: str) -> str:\n",
        "    return f\"{task}\\n\\nInput: {input_text}\\nOutput:\"\n",
        "\n",
        "def few_shot_prompt(task: str, examples: list[dict], input_text: str) -> str:\n",
        "    prompt = task + \"\\n\\n\"\n",
        "    for ex in examples:\n",
        "        prompt += f\"Input: {ex['input']}\\nOutput: {ex['output']}\\n\\n\"\n",
        "    prompt += f\"Input: {input_text}\\nOutput:\"\n",
        "    return prompt\n",
        "\n",
        "task = \"Classify the sentiment of the following text as POSITIVE, NEGATIVE, or NEUTRAL.\"\n",
        "examples = [\n",
        "    {\"input\": \"The product exceeded all my expectations.\",  \"output\": \"POSITIVE\"},\n",
        "    {\"input\": \"Delivery was delayed by two weeks.\",          \"output\": \"NEGATIVE\"},\n",
        "    {\"input\": \"The report was submitted on time.\",           \"output\": \"NEUTRAL\"},\n",
        "]\n",
        "test_text = \"Revenue grew 12% year-over-year driven by strong cloud adoption.\"\n",
        "\n",
        "print(\"=== ZERO-SHOT PROMPT ===\")\n",
        "print(zero_shot_prompt(task, test_text))\n",
        "print()\n",
        "print(\"=== FEW-SHOT PROMPT (k=3) ===\")\n",
        "print(few_shot_prompt(task, examples, test_text))"
      ],
