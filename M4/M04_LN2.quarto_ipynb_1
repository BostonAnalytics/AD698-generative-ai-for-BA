        "### Adapter Modules\n",
        "\n",
        "Adapters (Houlsby et al., 2019) insert small feed-forward bottleneck layers *inside* each\n",
        "transformer block."
      ],
      "id": "bd7e611c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "class AdapterModule(nn.Module):\n",
        "    \"\"\"Bottleneck adapter inserted after attention and FFN sub-layers.\"\"\"\n",
        "    def __init__(self, hidden_dim: int, bottleneck_dim: int, dropout: float = 0.1):\n",
        "        super().__init__()\n",
        "        self.down   = nn.Linear(hidden_dim, bottleneck_dim)\n",
        "        self.act    = nn.GELU()\n",
        "        self.up     = nn.Linear(bottleneck_dim, hidden_dim)\n",
        "        self.dropout= nn.Dropout(dropout)\n",
        "\n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        return x + self.up(self.dropout(self.act(self.down(x))))   # residual\n",
        "\n",
        "\n",
        "adapter = AdapterModule(hidden_dim=768, bottleneck_dim=64)\n",
        "x = torch.randn(2, 10, 768)\n",
        "print(f\"Adapter output: {adapter(x).shape}\")\n",
        "total = sum(p.numel() for p in adapter.parameters())\n",
        "print(f\"Trainable params: {total:,}  vs  768×768 = {768*768:,}\")"
      ],
