        "## Step 3: Use It in a Small Text Classifier"
      ],
      "id": "5de94a8e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "class LoRAClassifier(nn.Module):\n",
        "    def __init__(self, input_dim=32, hidden_dim=64, num_classes=2):\n",
        "        super().__init__()\n",
        "        self.fc1 = LoRALinear(input_dim, hidden_dim)\n",
        "        self.act = nn.ReLU()\n",
        "        self.fc2 = LoRALinear(hidden_dim, num_classes)\n",
        "\n",
        "    def forward(self, x):\n",
        "        return self.fc2(self.act(self.fc1(x)))"
      ],
