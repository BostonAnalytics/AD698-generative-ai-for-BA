        "x = torch.arange(-2.5, 2.5, 0.1)\n",
        "\n",
        "for kernel, name, ax in zip(kernels, names, axes):\n",
        "    ax.plot(x.detach().numpy(), kernel(x).detach().numpy())\n",
        "    ax.set_xlabel(name)\n",
        "plt.show()"
