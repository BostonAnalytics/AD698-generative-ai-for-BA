        "#| eval: false\n",
        "# Define some kernels\n",
        "def gaussian(x):\n",
        "    return torch.exp(-x**2 / 2)\n",
        "\n",
        "def boxcar(x):\n",
        "    return torch.abs(x) < 1.0\n",
        "\n",
        "def constant(x):\n",
        "    return 1.0 + 0 * x\n",
        "\n",
        "def epanechikov(x):\n",
        "    return torch.max(1 - torch.abs(x), torch.zeros_like(x))\n",
        "\n",
        "fig, axes = plt.subplots(1, 4, sharey=True, figsize=(12, 3))\n",
        "kernels = (gaussian, boxcar, constant, epanechikov)\n",
