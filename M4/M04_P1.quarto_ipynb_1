      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| eval: true\n",
        "\n",
        "def f(x):\n",
        "    return 2 * torch.sin(x) + x\n",
        "\n",
        "n = 40\n",
        "x_train = torch.sort(torch.rand(n) * 5)[0]\n",
        "y_train = f(x_train) + torch.randn(n)\n",
        "\n",
        "x_val = torch.arange(0, 5, 0.1)\n",
        "y_val = f(x_val)"
      ],
