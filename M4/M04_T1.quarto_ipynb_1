      "source": [
        "## Step 3: Minimal Transformer Classifier"
      ],
      "id": "880872d1"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "class TinyTransformerClassifier(nn.Module):\n",
        "    def __init__(self, vocab_size, embed_dim=32, heads=4, num_classes=2):\n",
        "        super().__init__()\n",
        "        self.embed = nn.Embedding(vocab_size, embed_dim, padding_idx=0)\n",
        "        self.attn = nn.MultiheadAttention(embed_dim, heads, batch_first=True)\n",
        "        self.norm = nn.LayerNorm(embed_dim)\n",
        "        self.head = nn.Linear(embed_dim, num_classes)\n",
        "\n",
        "    def forward(self, x):\n",
        "        h = self.embed(x)\n",
        "        a, _ = self.attn(h, h, h)\n",
        "        h = self.norm(h + a)\n",
        "        pooled = h.mean(dim=1)\n",
        "        return self.head(pooled)"
      ],
      "id": "8f17f6d4",
      "execution_count": null,
