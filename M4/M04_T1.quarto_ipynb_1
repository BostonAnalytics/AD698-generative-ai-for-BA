        "## Step 1: Create a Tiny Text Dataset"
      ],
      "id": "54ddf9b3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "texts = [\n",
        "    \"earnings exceeded expectations and outlook improved\",\n",
        "    \"regulatory pressure increased and costs rose sharply\",\n",
        "    \"management reaffirmed guidance and demand stayed stable\",\n",
        "]\n",
        "labels = [1, 0, 1]"
      ],
      "id": "f43e9ce7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "In the full lab, students should replace this with a text dataset such as `sentence polarity` or `yelp`.\n",
        "\n",
        "## Step 2: Tokenize to Integer IDs"
      ],
      "id": "21c2fe96"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "vocab = {\"<pad>\": 0}\n",
        "for txt in texts:\n",
        "    for tok in txt.split():\n",
        "        if tok not in vocab:\n",
        "            vocab[tok] = len(vocab)\n",
        "\n",
        "def encode(text, max_len=12):\n",
        "    ids = [vocab[t] for t in text.split()]\n",
        "    ids = ids[:max_len] + [0] * max(0, max_len - len(ids))\n",
        "    return ids\n",
        "\n",
        "X = torch.tensor([encode(t) for t in texts])\n",
        "y = torch.tensor(labels)\n",
        "X.shape, y.shape"
      ],
