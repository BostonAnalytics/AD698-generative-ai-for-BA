    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "DATA_DIR = Path(\"../data/SEC-10K-2024-HTML\")\n",
        "OUTPUT_DIR = Path(\"../data/outputs/sec_10k_sections\")\n",
        "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "ALL_HTML_FILES = sorted(DATA_DIR.rglob(\"*.html\")) + sorted(DATA_DIR.rglob(\"*.htm\"))\n",
