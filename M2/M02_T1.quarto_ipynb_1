      "source": [
        "## Select a small sample first\n",
        "\n",
        "Start small for debugging, then scale up for the assignment."
      ],
      "id": "4c1afb7c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def select_html_files(\n",
        "    files: List[Path],\n",
        "    sample_n: Optional[int] = None,\n",
        "    random_sample: bool = False,\n",
        "    random_state: int = 42\n",
        ") -> List[Path]:\n",
        "    if sample_n is None:\n",
        "        return files\n",
        "\n",
        "    sample_n = min(sample_n, len(files))\n",
        "    if random_sample:\n",
        "        rng = random.Random(random_state)\n",
        "        return sorted(rng.sample(files, sample_n))\n",
        "    return files[:sample_n]"
      ],
      "id": "f883a137",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "html_files = select_html_files(ALL_HTML_FILES, sample_n=25, random_sample=False)\n",
        "print(f\"Files selected: {len(html_files)}\")\n",
        "html_files[:5]"
      ],
      "id": "3f8bd1e5",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# HTML cleaning helpers"
      ],
      "id": "43f7b70d"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def normalize_text(text: str) -> str:\n",
        "    text = unicodedata.normalize(\"NFKC\", text)\n",
        "    text = text.replace(\"\\xa0\", \" \")\n",
        "    text = text.replace(\"&nbsp;\", \" \")\n",
        "    text = re.sub(r\"\\r\", \"\\n\", text)\n",
        "    text = re.sub(r\"\\n{2,}\", \"\\n\\n\", text)\n",
        "    text = re.sub(r\"[ \\t]+\", \" \", text)\n",
        "    return text.strip()\n",
        "\n",
        "\n",
        "def html_to_text(html: str) -> str:\n",
        "    soup = BeautifulSoup(html, \"lxml\")\n",
        "    for tag in soup([\"script\", \"style\", \"ix:header\", \"header\", \"footer\"]):\n",
        "        tag.decompose()\n",
        "    text = soup.get_text(separator=\"\\n\")\n",
        "    return normalize_text(text)"
      ],
      "id": "b3dd8c6f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Extract target SEC sections\n",
        "\n",
        "In Module 2, the key idea is that extraction must be **deterministic enough to audit**."
      ],
      "id": "cb768f0c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "ITEM_PATTERNS = {\n",
        "    \"item_1\": re.compile(r\"item\\s+1[^a-z0-9].*?(?=item\\s+1a[^a-z0-9]|item\\s+2[^a-z0-9])\", re.I | re.S),\n",
        "    \"item_1a\": re.compile(r\"item\\s+1a[^a-z0-9].*?(?=item\\s+1b[^a-z0-9]|item\\s+2[^a-z0-9])\", re.I | re.S),\n",
        "    \"item_7\": re.compile(r\"item\\s+7[^a-z0-9].*?(?=item\\s+7a[^a-z0-9]|item\\s+8[^a-z0-9])\", re.I | re.S),\n",
        "}\n",
        "\n",
        "\n",
        "def extract_sections(clean_text: str) -> Dict[str, Optional[str]]:\n",
        "    out = {}\n",
        "    for name, pattern in ITEM_PATTERNS.items():\n",
        "        match = pattern.search(clean_text)\n",
        "        out[name] = match.group(0).strip() if match else None\n",
        "    return out"
      ],
      "id": "d1e0496a",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Build a structured corpus table"
      ],
      "id": "7c1713ea"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "records = []\n",
        "\n",
        "for path in html_files:\n",
        "    raw_html = path.read_text(encoding=\"utf-8\", errors=\"ignore\")\n",
        "    clean_text = html_to_text(raw_html)\n",
        "    sections = extract_sections(clean_text)\n",
        "\n",
        "    records.append({\n",
        "        \"file_name\": path.name,\n",
        "        \"clean_char_count\": len(clean_text),\n",
        "        \"item_1_len\": len(sections[\"item_1\"]) if sections[\"item_1\"] else 0,\n",
        "        \"item_1a_len\": len(sections[\"item_1a\"]) if sections[\"item_1a\"] else 0,\n",
        "        \"item_7_len\": len(sections[\"item_7\"]) if sections[\"item_7\"] else 0,\n",
        "        \"item_1\": sections[\"item_1\"],\n",
        "        \"item_1a\": sections[\"item_1a\"],\n",
        "        \"item_7\": sections[\"item_7\"],\n",
        "    })\n",
        "\n",
        "corpus_df = pd.DataFrame(records)\n",
        "corpus_df.head()"
      ],
      "id": "e12ed278",
      "execution_count": null,
      "outputs": []
