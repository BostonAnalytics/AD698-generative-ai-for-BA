    "---\n",
    "title: \"Module 2 Assignment: Extracting Strategic Technology Signals from Form 10-K\"\n",
    "subtitle: \"Building a Retrieval-Ready Corpus for LLM Systems\"\n",
    "number-sections: true\n",
    "date: \"2026-02-15\"\n",
    "date-modified: today\n",
    "date-format: long\n",
    "engine: jupyter\n",
    "execute:\n",
