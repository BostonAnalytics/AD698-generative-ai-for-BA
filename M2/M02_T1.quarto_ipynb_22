        "#| eval: false\n",
        "#| code-overflow: wrap\n",
        "TARGET_SIGNAL = \"ai_investment\"\n",
        "EVIDENCE_FILE = OUTPUT_DIR / f\"sec_10k_2024_{TARGET_SIGNAL}_evidence_chunks.csv\""
