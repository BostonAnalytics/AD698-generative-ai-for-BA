      "source": [
        "#| echo: true\n",
        "#| eval: false\n",
        "#| code-overflow: wrap\n",
        "from pathlib import Path\n",
        "import pandas as pd\n",
        "import re\n",
        "\n",
        "OUTPUT_DIR = Path(\"./outputs/sec_10k_sections\")\n",
        "\n",
        "CHUNKS_FILE = OUTPUT_DIR / \"sec_10k_2024_sentence_window_chunks.csv\"\n",
        "SECTIONS_FILE = OUTPUT_DIR / \"sec_10k_2024_sections.csv\"\n",
        "\n",
