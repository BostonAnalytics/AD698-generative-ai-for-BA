{
  "version": "3.0.0",
  "tasks": [
    {
      "label": "Render and Zip Quarto Site",
      "type": "shell",
      "command": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-Command",
        "\"",
        "$ErrorActionPreference = \\\"Stop\\\";",
        "Write-Host '🔄 Starting Quarto render...' &&",
        "uv run quarto render --execute &&",
        "Write-Host '✅ Successfully created render.' &&",
        "Write-Host '📦 Now zipping site...' &&",
        "Compress-Archive -Force -Path _site -DestinationPath _site.zip &&",
        "Write-Host '🎉 Zip complete.' &&",
        "Write-Host '🧹 Cleaning intermediate .quarto_ipynb* files...' &&",
        "Get-ChildItem -Recurse -Include *.quarto_ipynb* | Remove-Item -Force &&",
        "Write-Host '✨ Cleanup complete.'",
        "\""
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}
