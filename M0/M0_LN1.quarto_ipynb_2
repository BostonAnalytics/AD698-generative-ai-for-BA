        "# CPU vs GPU Benchmark (Simple)"
      ],
      "id": "73082ced"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "import time\n",
        "import torch\n",
        "\n",
        "n = 2000\n",
        "a_cpu = torch.randn(n, n)\n",
        "b_cpu = torch.randn(n, n)\n",
        "\n",
        "t0 = time.time()\n",
        "_ = a_cpu @ b_cpu\n",
        "cpu_s = time.time() - t0\n",
        "\n",
        "if torch.cuda.is_available():\n",
        "    a_gpu = a_cpu.cuda()\n",
        "    b_gpu = b_cpu.cuda()\n",
        "    torch.cuda.synchronize()\n",
        "    t1 = time.time()\n",
        "    _ = a_gpu @ b_gpu\n",
        "    torch.cuda.synchronize()\n",
        "    gpu_s = time.time() - t1\n",
        "    print(f\"CPU: {cpu_s:.4f}s | GPU: {gpu_s:.4f}s\")\n",
        "else:\n",
        "    print(f\"CPU: {cpu_s:.4f}s | GPU not available\")"
      ],
      "id": "414f8a9f",
