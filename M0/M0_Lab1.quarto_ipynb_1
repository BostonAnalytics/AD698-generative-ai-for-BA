      "source": [
        "# Broadcasting\n",
        "\n",
        "Create:\n",
        "\n",
        "1. `m` as a `(3, 4)` tensor with values `0` to `11`.\n",
        "2. `bias` as a `(4,)` tensor `[0.1, 0.2, 0.3, 0.4]`.\n",
        "\n",
        "Then compute `m + bias` and explain in one sentence why this works."
      ],
      "id": "75abf3fe"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "# Your code here\n",
        "m = torch.arange(12).reshape(3, 4).float()\n",
        "bias = torch.tensor([0.1, 0.2, 0.3, 0.4])\n",
        "out = m + bias\n",
        "\n",
        "print(\"m:\\n\", m)\n",
        "print(\"bias:\", bias)\n",
        "print(\"m + bias:\\n\", out)"
      ],
      "id": "bed326a0",
      "execution_count": null,
      "outputs": []
    },
