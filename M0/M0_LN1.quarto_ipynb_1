        "# CPU vs GPU Benchmark (Simple)"
      ],
      "id": "1f4d0b44"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: true\n",
        "#| echo: true\n",
        "#| code-overflow: wrap\n",
        "#| label: tensor-benchmark\n",
        "\n",
        "import time\n",
        "import torch\n",
