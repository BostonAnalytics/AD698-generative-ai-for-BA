    "import torch, time\n",
    "\n",
    "n, d = 10_000, 512\n",
    "X = torch.randn(n, d); w = torch.randn(d)\n",
    "\n",
    "# Loop version (slow)\n",
    "start = time.time()\n",
    "y_loop = torch.zeros(n)\n",
    "for i in range(n):\n",
    "    y_loop[i] = (X[i] * w).sum()\n",
    "print(f\"Loop: {time.time()-start:.3f}s\")\n",
    "\n",
    "# Vectorized (fast)\n",
    "start = time.time()\n",
    "y_vec = X @ w\n",
    "print(f\"Vectorized: {time.time()-start:.4f}s\")\n",
    "\n",
    "# Result is identical\n",
    "assert torch.allclose(y_loop, y_vec, atol=1e-4)"
