   "metadata": {},
   "outputs": [],
   "source": [
    "#| eval: false\n",
    "def softmax(X):\n",
    "    X_exp = torch.exp(X - X.max(dim=1, keepdim=True).values)  # subtract max for stability\n",
    "    partition = X_exp.sum(dim=1, keepdim=True)\n",
    "    return X_exp / partition   # shape: [batch, num_classes]"
