    "#| eval: false\n",
    "class FixedHiddenMLP(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        # This weight is NOT a parameter — it will not be updated by the optimizer\n",
    "        self.rand_weight = torch.rand((20, 20))\n",
    "        self.linear = nn.Linear(20, 20)\n",
