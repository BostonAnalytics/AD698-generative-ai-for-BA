        "# Exercise C: chain rule intuition with autograd\n",
        "\n",
        "This section links calculus to PyTorch autograd [@zhang2023d2l]."
      ],
      "id": "d9d20d23"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "x = torch.tensor(3.0, requires_grad=True)\n",
        "y = x**2 + 2*x + 1  # y = (x+1)^2\n",
        "\n",
        "y.backward()\n",
        "print(\"x:\", x.item())\n",
        "print(\"autograd dy/dx:\", x.grad.item())\n",
        "print(\"analytic dy/dx:\", 2*x.item() + 2)"
      ],
      "id": "95718b2c",
      "execution_count": null,
      "outputs": []
    },
    {
