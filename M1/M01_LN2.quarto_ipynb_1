        "        fillcolor=\"#D5F5E3\"\n",
        "    ];\n",
        "\n",
        "    /* ===== Layout Control (Two Rows) ===== */\n",
        "    { rank=same; Text; Step1; Decision }\n",
        "    { rank=same; Step2; Step3; Record; Step4 }\n",
        "\n",
        "    /* ===== Edges ===== */\n",
