        "    ];\n",
        "\n",
        "    /* ===== Input Layer ===== */\n",
        "    Text [\n",
        "        label=\"Textual Data\\n(A statement)\",\n",
        "        fillcolor=\"#E8F1FA\"\n",
        "    ];\n",
        "\n",
        "    /* ===== Lexicons ===== */\n",
        "    Lex1 [\n",
        "        label=\"Corpus\",\n",
        "        shape=folder,\n",
        "        fillcolor=\"#FFF3CD\"\n",
