      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "#| eval: false\n",
        "from difflib import SequenceMatcher\n",
        "\n",
        "def similarity(a, b):\n",
        "    return SequenceMatcher(None, a, b).ratio()\n",
        "\n",
        "similarity(\n",
        "    \"risk management strategy\",\n",
        "    \"enterprise risk management\"\n",
        ")"
