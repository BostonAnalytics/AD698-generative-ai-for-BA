    "\n",
    "    /* ===== Input Layer ===== */\n",
    "    Text [\n",
    "        label=\"Textual Data\\n(A statement)\",\n",
    "        fillcolor=\"#E8F1FA\"\n",
    "    ];\n",
    "\n",
    "    /* ===== Lexicons ===== */\n",
