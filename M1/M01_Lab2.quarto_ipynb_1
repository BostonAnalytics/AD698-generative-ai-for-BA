        "\n",
        "# Using Pre-trained GloVe Embeddings\n",
        "\n",
        "Training embeddings from scratch requires a large corpus.\n",
        "In practice, we load **pre-trained embeddings** such as GloVe, which were trained on\n",
        "billions of tokens.\n",
        "\n",
        "The course provides a small GloVe-format file at `data/reviews-word2vec.tiny.txt`."
      ],
      "id": "ed8f57ff"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: load-glove\n",
        "#| eval: false\n",
        "GLOVE_PATH = Path(\"../../data/reviews-word2vec.tiny.txt\")\n",
        "\n",
        "glove: dict[str, np.ndarray] = {}\n",
        "with GLOVE_PATH.open(\"r\", encoding=\"utf-8\") as f:\n",
        "    for line in f:\n",
        "        parts = line.split()\n",
        "        word = parts[0]\n",
        "        vec = np.array(parts[1:], dtype=np.float32)\n",
        "        glove[word] = vec\n",
        "\n",
        "print(f\"Loaded {len(glove):,} pre-trained vectors\")\n",
        "print(f\"Vector dimension: {next(iter(glove.values())).shape[0]}\")"
      ],
      "id": "load-glove",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: glove-similarity\n",
        "#| eval: false\n",
        "def glove_sim(w1: str, w2: str) -> float | None:\n",
        "    if w1 not in glove or w2 not in glove:\n",
        "        return None\n",
        "    v1, v2 = glove[w1], glove[w2]\n",
        "    return float(np.dot(v1, v2) / (np.linalg.norm(v1) * np.linalg.norm(v2)))\n",
        "\n",
        "\n",
        "pairs = [\n",
        "    (\"good\", \"great\"),\n",
        "    (\"good\", \"bad\"),\n",
        "    (\"revenue\", \"income\"),\n",
        "    (\"bank\", \"finance\"),\n",
        "]\n",
        "\n",
        "print(f\"{'Word 1':<12} {'Word 2':<12} {'Cosine Sim':>12}\")\n",
        "print(\"-\" * 38)\n",
        "for w1, w2 in pairs:\n",
        "    sim = glove_sim(w1, w2)\n",
        "    if sim is not None:\n",
        "        print(f\"{w1:<12} {w2:<12} {sim:>12.4f}\")\n",
        "    else:\n",
        "        print(f\"{w1:<12} {w2:<12} {'(not in vocab)':>12}\")"
      ],
      "id": "glove-similarity",
      "execution_count": null,
      "outputs": []
    },
