        "\n",
        "import requests\n",
        "from pathlib import Path\n",
        "\n",
        "SEC_URL = (\n",
        "    \"https://www.sec.gov/Archives/edgar/data/\"\n",
        "    \"320193/000032019325000079/aapl-20250927.htm\"\n",
