        "#| echo: false\n",
        "#| eval: true\n",
        "#| label: fig-XOR-Problem\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# All possible binary inputs\n",
        "X = np.array([[0, 0],\n",
        "              [0, 1],\n",
        "              [1, 0],\n",
        "              [1, 1]])\n",
        "\n",
        "# Logic gate outputs\n",
        "def AND(x):   return np.array([a & b for a, b in x])\n",
        "def NAND(x):  return np.array([1 - (a & b) for a, b in x])\n",
        "def OR(x):    return np.array([a | b for a, b in x])\n",
        "def XOR(x):   return np.array([a ^ b for a, b in x])\n",
        "\n",
        "gates = {\n",
        "    \"AND\": AND(X),\n",
        "    \"NAND\": NAND(X),\n",
        "    \"OR\": OR(X),\n",
        "    \"XOR\": XOR(X),\n",
        "}\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(5,5))\n",
        "axes = axes.ravel()\n",
        "\n",
        "for ax, (name, y) in zip(axes, gates.items()):\n",
        "    # Plot points: 0 = blue circle, 1 = red diamond\n",
        "    for (x1, x2), label in zip(X, y):\n",
        "        if label == 0:\n",
        "            ax.scatter(x1, x2, c=\"#766100\", marker=\"o\", s=80)\n",
        "        else:\n",
        "            ax.scatter(x1, x2, c=\"#3e4587\", marker=\"D\", s=80)\n",
        "\n",
        "    # Add (optional) linear boundary for linearly separable ones\n",
        "    if name in [\"AND\", \"NAND\", \"OR\"]:\n",
        "        xs = np.linspace(-0.2, 1.2, 100)\n",
        "        if name == \"AND\":\n",
        "            # Example separating line: x1 + x2 = 1.5\n",
        "            ax.plot(xs, 1.5 - xs, color=\"#766100\")\n",
        "        elif name == \"NAND\":\n",
        "            # Example: x1 + x2 = 0.5\n",
        "            ax.plot(xs, 0.5 - xs, color=\"#766100\")\n",
        "        elif name == \"OR\":\n",
        "            # Example: x1 + x2 = 0.5\n",
        "            ax.plot(xs, 0.5 - xs, color=\"#3e4587\")\n",
        "\n",
        "    ax.set_title(name)\n",
        "    ax.set_xlim(-0.2, 1.2)\n",
        "    ax.set_ylim(-0.2, 1.2)\n",
        "    ax.set_xticks([0, 1])\n",
        "    ax.set_yticks([0, 1])\n",
        "    ax.set_xlabel(\"x1\")\n",
        "    ax.set_ylabel(\"x2\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
