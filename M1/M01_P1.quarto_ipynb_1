        "$$\n",
        "\\mathbf{x}_d = \\bigl[\\text{count}(w_1, d),\\; \\text{count}(w_2, d),\\; \\ldots,\\; \\text{count}(w_{|V|}, d)\\bigr]\n",
        "$$"
