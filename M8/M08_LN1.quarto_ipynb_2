        "\n",
        "    def forward(self, X):\n",
        "        assert hasattr(self, 'net'), \"Define self.net in your subclass\"\n",
        "        return self.net(X)\n",
        "\n",
        "    def plot(self, key, value, train):\n",
        "        assert hasattr(self, 'trainer'), \"Trainer must set self.trainer\"\n",
