        "#| echo: true\n",
        "#| eval: false\n",
        "\n",
        "def clean(text):\n",
        "    text = re.sub(r'<.*?>', ' ', text)  # remove HTML\n",
        "    text = text.lower()\n",
        "    return text\n",
        "\n",
        "all_reviews = []\n",
        "\n",
        "for folder in folders:\n",
        "    for file in os.scandir(folder):\n",
