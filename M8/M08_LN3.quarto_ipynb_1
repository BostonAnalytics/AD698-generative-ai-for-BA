        "\n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        cls_embeddings = x[:, 0, :]  \n",
        "\n",
        "        pooled_output = self.dense(cls_embeddings)\n",
        "        pooled_output = self.activation(pooled_output)\n",
        "\n",
        "        return pooled_output"
