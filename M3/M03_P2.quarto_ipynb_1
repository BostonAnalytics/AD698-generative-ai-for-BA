        "\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.patches import Rectangle, FancyArrowPatch\n",
        "import numpy as np\n",
        "\n",
        "# ---------------------------------------------------------\n",
        "# COLORS\n",
