        "$$\n",
        "\\begin{align}\n",
        "W =\n",
        "\\begin{bmatrix}\n",
        "W_{xh} \\\\\n",
        "W_{hh}\n",
        "\\end{bmatrix}\n",
        "\\in \\mathbb{R}^{(d_x + d_h) \\times d_h}\n",
        "\\end{align}\n",
        "$$\n",
