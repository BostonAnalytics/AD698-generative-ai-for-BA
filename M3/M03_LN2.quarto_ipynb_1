        "ax.set_xticks(range(T)); ax.set_xticklabels(tokens, rotation=45, ha=\"right\")\n",
        "ax.set_yticks(range(T)); ax.set_yticklabels(tokens)\n",
        "ax.set_title(\"Attention Weight Matrix (single head)\")\n",
        "plt.colorbar(im, ax=ax)\n",
