    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "#| eval: false\n",
        "\n",
        "import re\n",
        "\n",
        "def normalize_text_for_matching(text):\n",
        "    text = re.sub(r'\\xa0', ' ', text)\n",
        "    text = re.sub(r'&nbsp;', ' ', text)\n",
        "    text = re.sub(r'\\s+', ' ', text)\n",
        "    return text\n",
        "\n",
        "def extract_item_section(html_text, item_label, next_item_labels):\n",
        "    \"\"\"\n",
        "    Extract a section beginning at item_label and ending before the first match\n",
        "    of any label in next_item_labels.\n",
        "    \"\"\"\n",
        "    text = normalize_text_for_matching(html_text)\n",
        "\n",
        "    start_pattern = re.compile(rf'item\\s*{re.escape(item_label)}[\\.\\:\\-\\s]', re.IGNORECASE)\n",
        "    start_match = start_pattern.search(text)\n",
        "\n",
        "    if not start_match:\n",
        "        return None\n",
        "\n",
        "    start_idx = start_match.start()\n",
        "\n",
        "    end_idx = len(text)\n",
        "    for next_label in next_item_labels:\n",
        "        next_pattern = re.compile(rf'item\\s*{re.escape(next_label)}[\\.\\:\\-\\s]', re.IGNORECASE)\n",
        "        next_match = next_pattern.search(text, pos=start_match.end())\n",
        "        if next_match:\n",
        "            end_idx = min(end_idx, next_match.start())\n",
        "\n",
        "    return text[start_idx:end_idx].strip()"
      ],
