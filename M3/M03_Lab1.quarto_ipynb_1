        "#| eval: false\n",
        "import os, re, pathlib, textwrap\n",
        "from pathlib import Path\n",
        "import numpy as np\n",
        "import faiss\n",
        "import chromadb\n",
        "from sentence_transformers import SentenceTransformer\n",
        "\n",
        "EMBED_MODEL = \"all-MiniLM-L6-v2\"\n",
        "embedder    = SentenceTransformer(EMBED_MODEL)\n",
        "print(f\"Embedding model: {EMBED_MODEL}\")\n",
        "print(f\"Output dimension: {embedder.get_sentence_embedding_dimension()}\")"
      ],
      "id": "e4efa26c",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Load SEC 10-K Filings"
      ],
      "id": "ffed2f5a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "data_dir = Path(\"../data/SEC-10K-2024\")\n",
        "txt_files = sorted(data_dir.glob(\"*.txt\"))\n",
        "print(f\"Found {len(txt_files)} 10-K text files:\")\n",
        "for f in txt_files[:10]:\n",
        "    print(f\"  {f.name}  ({f.stat().st_size // 1024:,} KB)\")"
      ],
      "id": "674d5908",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "def load_filing(filepath: Path) -> str:\n",
        "    return filepath.read_text(encoding=\"utf-8\", errors=\"replace\")\n",
        "\n",
        "filings = {f.stem: load_filing(f) for f in txt_files[:3]}\n",
        "for name, text in filings.items():\n",
        "    print(f\"{name}: {len(text):,} chars\")"
      ],
      "id": "38e72447",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Document Chunking"
      ],
      "id": "0b1eafdf"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "def chunk_text(text, source, chunk_size=300, overlap=50):\n",
        "    words  = text.split()\n",
        "    chunks = []\n",
        "    step   = chunk_size - overlap\n",
        "    for i, start in enumerate(range(0, len(words), step)):\n",
        "        w = words[start : start + chunk_size]\n",
        "        if len(w) < 20:\n",
        "            break\n",
        "        chunks.append({\"id\": f\"{source}_chunk_{i:04d}\", \"text\": \" \".join(w),\n",
        "                        \"source\": source, \"chunk_idx\": i})\n",
        "    return chunks\n",
        "\n",
        "corpus = []\n",
        "for source, text in filings.items():\n",
        "    chunks = chunk_text(text, source)\n",
        "    corpus.extend(chunks)\n",
        "    print(f\"{source}: {len(chunks)} chunks\")\n",
        "print(f\"\\nTotal chunks: {len(corpus)}\")"
      ],
      "id": "980c99ad",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Embedding the Corpus"
      ],
      "id": "fbf6b5d5"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "texts = [c[\"text\"] for c in corpus]\n",
        "embeddings = embedder.encode(texts, batch_size=64, show_progress_bar=True,\n",
        "                             convert_to_numpy=True, normalize_embeddings=True)\n",
        "print(f\"Embeddings shape: {embeddings.shape}\")"
      ],
      "id": "289e8fc9",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Build a FAISS Index"
      ],
      "id": "1581e781"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "dim   = embeddings.shape[1]\n",
        "index = faiss.IndexFlatIP(dim)\n",
        "index.add(embeddings.astype(np.float32))\n",
        "print(f\"FAISS index size: {index.ntotal:,} vectors\")"
      ],
      "id": "41a7d4f5",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "def search_faiss(query, k=5):\n",
        "    q = embedder.encode([query], normalize_embeddings=True).astype(np.float32)\n",
        "    scores, idxs = index.search(q, k)\n",
        "    results = []\n",
        "    for rank, (s, i) in enumerate(zip(scores[0], idxs[0])):\n",
        "        r = corpus[i].copy(); r[\"score\"] = float(s); r[\"rank\"] = rank + 1\n",
        "        results.append(r)\n",
        "    return results\n",
        "\n",
        "query = \"cloud computing revenue growth risk factors\"\n",
        "results = search_faiss(query, k=5)\n",
        "print(f\"Query: {query}\\n\")\n",
        "for r in results:\n",
        "    print(f\"Rank {r['rank']} (score={r['score']:.4f}) — {r['source']} chunk {r['chunk_idx']}\")\n",
        "    print(textwrap.fill(r['text'][:200], width=90))\n",
        "    print()"
      ],
      "id": "654e6d3f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Build a ChromaDB Collection"
      ],
      "id": "3b9fcf6f"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "chroma_client = chromadb.PersistentClient(path=\"./chroma_store\")\n",
        "COLLECTION_NAME = \"sec10k_lab\"\n",
        "try:\n",
        "    chroma_client.delete_collection(COLLECTION_NAME)\n",
        "except Exception:\n",
        "    pass\n",
        "collection = chroma_client.create_collection(\n",
        "    name=COLLECTION_NAME, metadata={\"hnsw:space\": \"cosine\"})\n",
        "print(f\"Created collection: {COLLECTION_NAME}\")"
      ],
      "id": "94a25efe",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "BATCH = 500\n",
        "for start in range(0, len(corpus), BATCH):\n",
        "    batch = corpus[start : start + BATCH]\n",
        "    collection.add(\n",
        "        ids        = [c[\"id\"]   for c in batch],\n",
        "        documents  = [c[\"text\"] for c in batch],\n",
        "        metadatas  = [{\"source\": c[\"source\"], \"chunk_idx\": c[\"chunk_idx\"]} for c in batch],\n",
        "        embeddings = embeddings[start : start + BATCH].tolist(),\n",
        "    )\n",
        "print(f\"ChromaDB collection size: {collection.count():,}\")"
      ],
      "id": "aa652407",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "def search_chroma(query, k=5, source_filter=None):\n",
        "    where = {\"source\": source_filter} if source_filter else None\n",
        "    q = embedder.encode([query], normalize_embeddings=True).tolist()\n",
        "    res = collection.query(query_embeddings=q, n_results=k, where=where)\n",
        "    results = []\n",
        "    for i, (doc, meta, dist) in enumerate(\n",
        "            zip(res[\"documents\"][0], res[\"metadatas\"][0], res[\"distances\"][0])):\n",
        "        results.append({\"rank\": i+1, \"text\": doc, \"source\": meta[\"source\"],\n",
        "                        \"chunk_idx\": meta[\"chunk_idx\"], \"distance\": dist})\n",
        "    return results\n",
        "\n",
        "results_chroma = search_chroma(query, k=5)\n",
        "for r in results_chroma:\n",
        "    print(f\"Rank {r['rank']} (dist={r['distance']:.4f}) — {r['source']} chunk {r['chunk_idx']}\")\n",
        "    print(textwrap.fill(r['text'][:200], width=90)); print()"
      ],
      "id": "73a3f7c8",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Compare FAISS vs ChromaDB"
      ],
      "id": "3087e6a4"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "faiss_ids  = {(r['source'], r['chunk_idx']) for r in results}\n",
        "chroma_ids = {(r['source'], r['chunk_idx']) for r in results_chroma}\n",
        "overlap = faiss_ids & chroma_ids\n",
        "print(f\"FAISS  top-5 IDs : {faiss_ids}\")\n",
        "print(f\"Chroma top-5 IDs : {chroma_ids}\")\n",
        "print(f\"Overlap: {len(overlap)}/5\")"
      ],
      "id": "752b4248",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## RAG Prompt Formatter"
      ],
      "id": "b285663c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "def build_rag_prompt(query, k=3, backend=\"faiss\"):\n",
        "    retrieved = search_faiss(query, k) if backend == \"faiss\" else search_chroma(query, k)\n",
        "    ctx = \"\\n\\n---\\n\\n\".join(\n",
        "        f\"[Source: {r['source']}, chunk {r['chunk_idx']}]\\n{r['text']}\" for r in retrieved)\n",
        "    return (\n",
        "        \"You are a financial analyst assistant specializing in SEC 10-K filings.\\n\"\n",
        "        \"Use ONLY the context below to answer the question.\\n\"\n",
        "        \"If the answer is not in the context, say \"\n",
        "        '\"I cannot determine this from the provided filings.\"\\n\\n'\n",
        "        f\"Context:\\n{ctx}\\n\\nQuestion: {query}\\n\\nAnswer:\"\n",
        "    )\n",
        "\n",
        "print(build_rag_prompt(\"What are the main risk factors related to competition?\", k=3)[:1500])"
      ],
      "id": "ba8854dc",
      "execution_count": null,
      "outputs": []
