        "#| echo: true\n",
        "#| eval: true\n",
        "\n",
        "import os\n",
        "import re\n",
        "import torch\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "import requests\n",
        "import random\n",
        "\n",
        "class TimeMachineDataset(Dataset):\n",
        "    URL = \"https://d2l-data.s3-accelerate.amazonaws.com/timemachine.txt\"\n",
        "\n",
        "    def __init__(self, num_steps, split=\"train\",\n",
        "                 root=\"data\", num_train=10000, num_val=5000):\n",
        "        super().__init__()\n",
        "        self.num_steps = num_steps\n",
        "        self.split = split\n",
        "        self.root = root\n",
        "        self.num_train = num_train\n",
        "        self.num_val = num_val\n",
        "\n",
        "        os.makedirs(root, exist_ok=True)\n",
        "        path = os.path.join(root, \"timemachine.txt\")\n",
        "\n",
        "        # --- download ---\n",
        "        if not os.path.exists(path):\n",
        "            r = requests.get(self.URL)\n",
        "            with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "                f.write(r.text)\n",
        "\n",
        "        with open(path, \"r\", encoding=\"utf-8\") as f:\n",
        "            raw = f.read()\n",
        "\n",
        "        # --- preprocess ---\n",
        "        text = raw.lower()\n",
        "        text = re.sub(r\"[^a-z]+\", \" \", text)\n",
        "        text = re.sub(r\"\\s+\", \" \", text).strip()\n",
        "\n",
        "        # --- vocabulary ---\n",
        "        chars = sorted(list(set(text)))\n",
        "        self.vocab = {c: i for i, c in enumerate(chars)}\n",
        "        self.inv_vocab = {i: c for c, i in self.vocab.items()}\n",
        "\n",
        "        corpus = torch.tensor([self.vocab[c] for c in text], dtype=torch.long)\n",
        "\n",
        "        # --- build all subsequences ---\n",
        "        seqs = torch.stack([\n",
        "            corpus[i:i+num_steps+1]\n",
        "            for i in range(len(corpus) - num_steps)\n",
        "        ])\n",
        "\n",
        "        X, Y = seqs[:, :-1], seqs[:, 1:]\n",
        "\n",
        "        # --- split ---\n",
        "        if split == \"train\":\n",
        "            self.X = X[:num_train]\n",
        "            self.Y = Y[:num_train]\n",
        "        else:\n",
        "            start = num_train\n",
        "            end = num_train + num_val\n",
        "            self.X = X[start:end]\n",
        "            self.Y = Y[start:end]\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.X)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        return self.X[idx], self.Y[idx]"
      ],
