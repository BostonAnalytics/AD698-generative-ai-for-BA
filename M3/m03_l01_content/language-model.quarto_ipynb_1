        "#| echo: true\n",
        "#| eval: true\n",
        "train_loader = get_timemachine_dataloader(batch_size=2, num_steps=10)\n",
        "\n",
        "for X, Y in train_loader:\n",
        "    print(\"X:\", X)\n",
        "    print(\"Y:\", Y)\n",
        "    break"
