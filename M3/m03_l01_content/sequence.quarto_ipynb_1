        "\n",
        "set_economist_theme()\n",
        "plt.figure(figsize=(7, 4.5))\n",
        "\n",
        "start = data.tau + steps[-1] - 1\n",
        "time = data.time[start:].numpy()\n",
        "\n",
        "for k in steps:\n",
        "    plt.plot(\n",
        "        time,\n",
        "        pred_rows[k-1].numpy(),\n",
        "        label=f\"{k}-step preds\",\n",
        "        linewidth=1.0\n",
        "    )\n",
        "\n",
        "plt.xlabel(\"time\")\n",
        "plt.ylabel(\"x\")\n",
        "plt.title(\"k-step Ahead Predictions\")\n",
        "plt.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
