        "### PyTorch Linear Regression Model\n",
        "\n",
        "In this example our model will be a standard linear regression."
      ],
      "id": "a8941f24"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "#| eval: true\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "\n",
        "class LinearRegression(nn.Module):\n",
        "    def __init__(self, lr=0.01):\n",
        "        super().__init__()\n",
        "        self.net = nn.Linear(4, 1)  # tau = 4 in your Data class\n",
        "        self.loss_fn = nn.MSELoss()\n",
        "        self.lr = lr\n",
        "\n",
        "    def forward(self, X):\n",
        "        return self.net(X)\n",
        "\n",
        "    def training_step(self, batch):\n",
        "        X, y = batch\n",
        "        y_hat = self(X)\n",
        "        return self.loss_fn(y_hat, y)\n",
        "\n",
        "    def validation_step(self, batch):\n",
        "        X, y = batch\n",
        "        y_hat = self(X)\n",
        "        return self.loss_fn(y_hat, y)"
      ],
      "id": "6c69d106",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### PyTorch‑Native Trainer With Train/Test Loss Logging"
      ],
      "id": "8218d12b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "#| eval: true\n",
        "from torch.utils.data import DataLoader\n",
        "\n",
        "class Trainer:\n",
        "    def __init__(self, max_epochs=5, device=None):\n",
        "        self.max_epochs = max_epochs\n",
        "        self.device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "        self.train_losses = []\n",
        "        self.test_losses = []\n",
        "\n",
        "    def fit(self, model, data):\n",
        "        model.to(self.device)\n",
        "        train_loader = data.get_dataloader(train=True)\n",
        "        test_loader = data.get_dataloader(train=False)\n",
        "\n",
        "        optimizer = torch.optim.SGD(model.parameters(), lr=model.lr)\n",
        "\n",
        "        for epoch in range(self.max_epochs):\n",
        "            model.train()\n",
        "            epoch_train_loss = 0\n",
        "\n",
        "            for X, y in train_loader:\n",
        "                X, y = X.to(self.device), y.to(self.device)\n",
        "                loss = model.training_step((X, y))\n",
        "\n",
        "                optimizer.zero_grad()\n",
        "                loss.backward()\n",
        "                optimizer.step()\n",
        "\n",
        "                epoch_train_loss += loss.item()\n",
        "\n",
        "            epoch_train_loss /= len(train_loader)\n",
        "            self.train_losses.append(epoch_train_loss)\n",
        "\n",
        "            # Validation\n",
        "            model.eval()\n",
        "            epoch_test_loss = 0\n",
        "            with torch.no_grad():\n",
        "                for X, y in test_loader:\n",
        "                    X, y = X.to(self.device), y.to(self.device)\n",
        "                    loss = model.validation_step((X, y))\n",
        "                    epoch_test_loss += loss.item()\n",
        "\n",
        "            epoch_test_loss /= len(test_loader)\n",
        "            self.test_losses.append(epoch_test_loss)\n",
        "\n",
        "            print(f\"Epoch {epoch+1}: train={epoch_train_loss:.4f}, test={epoch_test_loss:.4f}\")"
      ],
      "id": "31ef56b7",
      "execution_count": null,
      "outputs": []
    },
