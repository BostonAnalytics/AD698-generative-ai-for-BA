        "#| fig-align: center\n",
        "#| fig-alt: Word frequency distribution (log-log plot)\n",
        "#| fig-cap: Word frequency distribution (log-log plot)\n",
        "#| label: fig-word-frequency\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
