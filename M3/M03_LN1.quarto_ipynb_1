      "source": [
        "#| echo: true\n",
        "#| eval: true\n",
        "from torch.utils.data import DataLoader\n",
        "\n",
        "class Trainer:\n",
        "    def __init__(self, max_epochs=5, device=None):\n",
        "        self.max_epochs = max_epochs\n",
        "        self.device = device or (\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "        self.train_losses = []\n",
        "        self.test_losses = []\n",
        "\n",
        "    def fit(self, model, data):\n",
        "        model.to(self.device)\n",
        "        train_loader = data.get_dataloader(train=True)\n",
        "        test_loader = data.get_dataloader(train=False)\n",
        "\n",
        "        optimizer = torch.optim.SGD(model.parameters(), lr=model.lr)\n",
        "\n",
        "        for epoch in range(self.max_epochs):\n",
        "            model.train()\n",
        "            epoch_train_loss = 0\n",
        "\n",
        "            for X, y in train_loader:\n",
        "                X, y = X.to(self.device), y.to(self.device)\n",
        "                loss = model.training_step((X, y))\n",
        "\n",
        "                optimizer.zero_grad()\n",
        "                loss.backward()\n",
        "                optimizer.step()\n",
        "\n",
        "                epoch_train_loss += loss.item()\n",
        "\n",
        "            epoch_train_loss /= len(train_loader)\n",
        "            self.train_losses.append(epoch_train_loss)\n",
        "\n",
        "            # Validation\n",
        "            model.eval()\n",
        "            epoch_test_loss = 0\n",
        "            with torch.no_grad():\n",
        "                for X, y in test_loader:\n",
        "                    X, y = X.to(self.device), y.to(self.device)\n",
        "                    loss = model.validation_step((X, y))\n",
        "                    epoch_test_loss += loss.item()\n",
        "\n",
        "            epoch_test_loss /= len(test_loader)\n",
        "            self.test_losses.append(epoch_test_loss)\n",
        "\n",
        "            print(f\"Epoch {epoch+1}: train={epoch_train_loss:.4f}, test={epoch_test_loss:.4f}\")"
      ],
