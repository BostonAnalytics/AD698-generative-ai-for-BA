        "## Create regex patterns\n",
        "\n",
        "We will compile patterns once and reuse them."
      ],
      "id": "dc6064c6"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "#| eval: true\n",
        "#| code-overflow: wrap\n",
        "\n",
        "def build_phrase_pattern(terms):\n",
        "    \"\"\"\n",
        "    Build a case-insensitive regex pattern from a list of phrases.\n",
        "    \"\"\"\n",
        "    escaped_terms = [re.escape(term) for term in terms]\n",
        "    pattern = r\"\\b(?:%s)\\b\" % \"|\".join(escaped_terms)\n",
        "    return re.compile(pattern, flags=re.IGNORECASE)"
      ],
      "id": "552dbdc8",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
