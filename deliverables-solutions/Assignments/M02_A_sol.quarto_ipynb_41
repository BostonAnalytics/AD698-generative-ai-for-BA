    "                \"item_7_len\": 0,\n",
    "                \"missing_item_1\": True,\n",
    "                \"missing_item_1a\": True,\n",
    "                \"missing_item_7\": True,\n",
    "                \"status\": \"error\",\n",
    "                \"error\": str(e),\n",
    "            }\n",
    "            records.append(error_record)\n",
    "\n",
    "            recheck_records.append({\n",
    "                **metadata,\n",
    "                \"raw_text_length\": None,\n",
