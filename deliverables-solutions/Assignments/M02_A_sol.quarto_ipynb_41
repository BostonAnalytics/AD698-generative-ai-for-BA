    "```python\n",
    "def build_rolling_chunks(\n",
    "    df: pd.DataFrame,\n",
    "    window_size: int = 3,\n",
    "    step: int = 1\n",
    ") -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Build rolling multi-sentence chunks within each file and section.\n",
    "    \"\"\"\n",
    "    chunk_rows = []\n",
    "\n",
    "    grouped = df.sort_values([\"file_name\", \"section_name\", \"sentence_number\"]) \\\n",
    "                .groupby([\"file_name\", \"file_path\", \"section_name\"], as_index=False)\n",
    "\n",
    "    for (file_name, file_path, section_name), group in grouped:\n",
    "        group = group.sort_values(\"sentence_number\").reset_index(drop=True)\n",
    "\n",
    "        sentences = group[\"sentence_text\"].tolist()\n",
    "        sentence_numbers = group[\"sentence_number\"].tolist()\n",
    "\n",
    "        for start in range(0, len(sentences), step):\n",
    "            end = start + window_size\n",
    "            window_sents = sentences[start:end]\n",
    "\n",
    "            if not window_sents:\n",
    "                continue\n",
    "\n",
    "            chunk_text = \" \".join(window_sents).strip()\n",
    "            if not chunk_text:\n",
    "                continue\n",
    "\n",
    "            chunk_rows.append({\n",
    "                \"file_name\": file_name,\n",
    "                \"file_path\": file_path,\n",
    "                \"section_name\": section_name,\n",
    "                \"chunk_id\": f\"{file_name}::{section_name}::c{start+1}\",\n",
    "                \"start_sentence\": sentence_numbers[start],\n",
    "                \"end_sentence\": sentence_numbers[min(end - 1, len(sentence_numbers) - 1)],\n",
    "                \"chunk_text\": chunk_text,\n",
    "                \"chunk_length\": len(chunk_text),\n",
    "                \"n_sentences\": len(window_sents)\n",
    "            })\n",
    "\n",
    "    return pd.DataFrame(chunk_rows)\n",
    "```\n",
