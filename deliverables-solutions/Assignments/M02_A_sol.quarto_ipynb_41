    "---\n",
    "\n",
    "# Step 4: Sentence cleaning helper\n",
    "\n",
    "We want light cleanup only, not aggressive rewriting.\n",
    "\n",
    "```python\n",
    "def clean_sentence(text: str) -> str:\n",
    "    \"\"\"\n",
    "    Light sentence cleanup for SEC filing text.\n",
    "    \"\"\"\n",
    "    text = str(text)\n",
    "    text = text.replace(\"\\xa0\", \" \")\n",
    "    text = re.sub(r\"\\s+\", \" \", text)\n",
    "    return text.strip()\n",
    "```\n",
    "\n",
    "---\n",
    "\n",
    "# Step 5: Chunk sections into sentences\n",
    "\n",
    "This creates one row per sentence.\n",
    "\n",
    "```python\n",
    "sentence_rows = []\n",
    "\n",
    "for _, row in df_long.iterrows():\n",
    "    text = row[\"section_text\"]\n",
    "    sentences = sent_tokenize(text)\n",
    "\n",
    "    for i, sent in enumerate(sentences, start=1):\n",
    "        sent_clean = clean_sentence(sent)\n",
    "\n",
    "        if not sent_clean:\n",
    "            continue\n",
    "\n",
    "        sentence_rows.append({\n",
    "            \"file_name\": row[\"file_name\"],\n",
    "            \"file_path\": row[\"file_path\"],\n",
    "            \"section_name\": row[\"section_name\"],\n",
    "            \"sentence_id\": f\"{row['file_name']}::{row['section_name']}::s{i}\",\n",
    "            \"sentence_number\": i,\n",
    "            \"sentence_text\": sent_clean,\n",
    "            \"sentence_length\": len(sent_clean),\n",
    "            \"section_length\": row[\"section_length\"]\n",
    "        })\n",
    "\n",
    "df_sentences = pd.DataFrame(sentence_rows)\n",
    "\n",
    "print(df_sentences.shape)\n",
    "df_sentences.head()\n",
    "```\n",
    "\n",
