    "                })\n",
    "\n",
    "        except Exception as e:\n",
    "            metadata = extract_basic_metadata(file_path)\n",
    "\n",
    "            error_record = {\n",
    "                **metadata,\n",
    "                \"raw_text_length\": None,\n",
    "                \"item_1\": None,\n",
    "                \"item_1a\": None,\n",
    "                \"item_7\": None,\n",
